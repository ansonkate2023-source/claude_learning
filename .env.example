# GitHub token for API access (optional)
GITHUB_TOKEN=

# Git remote push (set to "true" to enable auto-push)
GIT_AUTO_PUSH=false

# Data output directory (default: ./data)
DATA_DIR=./data

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum retries for failed requests
MAX_RETRIES=3

# Delay between requests to same source (seconds)
REQUEST_DELAY=1.0
